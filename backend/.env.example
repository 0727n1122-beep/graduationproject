# Anthropic API 설정
# 수업용 Virtual Key 사용 시 아래 두 줄 모두 필요
ANTHROPIC_BASE_URL=http://43.201.226.184:4000
ANTHROPIC_API_KEY=your_virtual_key_here

# 개인 Anthropic 계정 사용 시 BASE_URL 제거하고 아래만 입력
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# CORS 허용 도메인 (쉼표로 구분, 배포 후 프론트 URL로 변경)
# 예: https://your-frontend.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=*